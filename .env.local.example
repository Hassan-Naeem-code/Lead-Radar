# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# --- Supabase (Phase 1) ---
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Project Settings -> API -> service_role (SECRET — server only, never exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe (Phase 4) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...          # from `stripe listen`
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin panel (Phase 6) ---
# The admin has its own login at /admin/login — a SEPARATE credential, not a normal
# user account, and there is no admin signup. These are the fixed starting values;
# on first login they're saved to the DB, then the password is changed from
# /admin/account. Set a strong password here for the very first login.
ADMIN_EMAIL=you@fresh-leads.io
# Wrap the password in quotes if it contains a # (otherwise it's read as a comment).
ADMIN_PASSWORD="change-this-strong-first-password"
# Optional — overrides the session-cookie signing secret (defaults to the
# service-role key, which is already a strong secret, so this is optional).
ADMIN_SESSION_SECRET=

# --- Optional paid upgrades (later; leave blank to stay on the free tier) ---
GOOGLE_PLACES_API_KEY=
ZEROBOUNCE_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
