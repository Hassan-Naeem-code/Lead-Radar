# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# --- Supabase (Phase 1) ---
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Project Settings -> API -> service_role (SECRET — server only, never exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe (Phase 4) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...          # from `stripe listen`
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional paid upgrades (later; leave blank to stay on the free tier) ---
GOOGLE_PLACES_API_KEY=
ZEROBOUNCE_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
